# =============================================================================
#  KrishiDrishti — .gitignore
#  Excludes model weights, datasets, virtual envs, and generated files.
#  DO NOT commit model weights or datasets — they are too large for Git.
#  Use Git LFS or Kaggle/HuggingFace Hub for large binary files.
# =============================================================================


# ── Python bytecode & caches ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python


# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/


# ── ML model weights & checkpoints ───────────────────────────────────────────
# Never commit trained model files — they can be 100s of MB.
# Reproduce them by running: ./run.sh --train
*.pt
*.pth
*.ckpt
*.pkl
*.h5
*.hdf5
*.onnx
*.tflite
*.pb
model/best_model.pt
model/training_history.json


# ── Dataset directories ───────────────────────────────────────────────────────
# Download datasets separately from Kaggle / official sources.
# See README.md — "To Train the Real Model" section.
data/
datasets/
*.csv
*.parquet


# ── Training & server logs ────────────────────────────────────────────────────
logs/
*.log
*.log.*


# ── IDE and editor config ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db


# ── Jupyter notebooks (generated outputs) ────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints


# ── Build & distribution ──────────────────────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/
*.egg
MANIFEST


# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
*.cover
coverage.xml
nosetests.xml
test-results/


# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.pyright/
pyrightconfig.json


# ── Environment variable files ────────────────────────────────────────────────
# Keep .env.example in Git, but never .env (it may contain secrets)
.env
.env.local
.env.*.local
secrets.json


# ── Static file uploads (user-uploaded leaf images) ──────────────────────────
static/uploads/
uploads/


# ── OS generated files ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# ── Flask instance folder ─────────────────────────────────────────────────────
instance/
flask_session/


# ── Temporary files ───────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig


# ── What IS committed (for reference) ────────────────────────────────────────
# ✓ app.py
# ✓ model/classifier.py
# ✓ templates/index.html
# ✓ requirements.txt
# ✓ config.json
# ✓ run.sh
# ✓ test_basic.py
# ✓ .gitignore
# ✓ README.md
# ✗ model/*.pt          (too large — generated by training)
# ✗ data/               (too large — download from Kaggle)
# ✗ .venv/              (generated by pip — use requirements.txt)
# ✗ logs/               (generated at runtime)
